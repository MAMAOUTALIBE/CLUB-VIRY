# ===========================================================================
# Configuration de PRODUCTION — mode CRM (Supabase) — esvirychatillonfootball.org
#
# Sur le VPS :  cp .env.production.crm.example .env.local   puis remplir les 3 cles Supabase.
# ⚠️ Les variables NEXT_PUBLIC_* sont INLINEES AU BUILD par Next.js : apres toute
#    modification ici, il faut REBUILD (deploy.sh le fait), pas juste redemarrer.
# ===========================================================================

# --- Identite publique du site ---------------------------------------------
# URL publique complete (SEO, sitemap, robots, liens canoniques, OpenGraph).
NEXT_PUBLIC_SITE_URL=https://esvirychatillonfootball.org
# Origines autorisees pour les requetes navigateur mutantes (defense CSRF).
CSRF_ALLOWED_ORIGINS=https://esvirychatillonfootball.org,https://www.esvirychatillonfootball.org
# Domaine route par Traefik (sans le https://). Sert aux labels docker-compose.
SITE_DOMAIN=esvirychatillonfootball.org

# --- Mode CRM complet (Supabase) — REQUIS ----------------------------------
# Recommande : un projet Supabase Cloud (https://supabase.com, plan gratuit suffisant
# pour demarrer). Recuperer dans Project Settings > API :
#   - Project URL                -> NEXT_PUBLIC_SUPABASE_URL
#   - Project API keys: anon     -> NEXT_PUBLIC_SUPABASE_ANON_KEY
#   - Project API keys: service_role (SECRET, cote serveur) -> SUPABASE_SERVICE_ROLE_KEY
# Appliquer ensuite les migrations supabase/migrations/*.sql puis supabase/seed.sql.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Capture des demandes (toujours active, meme en CRM) -------------------
# Monte en volume -> les demandes restent sur le VPS apres une mise a jour.
LEADS_DIR=/app/var/leads

# --- Notifications temps reel des demandes (optionnel, recommande) ---------
# NOTIFICATION_WEBHOOK_URL=
# NOTIFICATION_WEBHOOK_SECRET=
ADMIN_NOTIFICATIONS_EMAIL=esvirychatillon91170@gmail.com

# --- Envoi REEL des emails transactionnels (familles) — optionnel ----------
# Brevo : ~300 emails/jour en plan gratuit. Sans cle, les emails restent en file.
# BREVO_API_KEY=
# EMAIL_FROM=contact@esvirychatillonfootball.org
# EMAIL_FROM_NAME=ES Viry-Chatillon Football

# --- Plateforme Academy (formation) : page /academy redirige vers cette URL --
ACADEMY_PLATFORM_URL=

# ===========================================================================
# Variables lues par deploy.sh DEPUIS TON MAC (pas par Next.js).
# A definir dans ton shell local, PAS forcement ici (ne commite jamais un vrai hote SSH) :
#   VPS_HOST=root@IP_DU_VPS    VPS_PORT=22    DEPLOY_MODE=crm
# ===========================================================================
