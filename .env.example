NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Mode vitrine (sans Supabase) ---
# Les demandes (contact / inscription / recrutement) sont toujours enregistrees
# dans un fichier (LEADS_DIR). En plus, si une URL de webhook est definie ci-dessous,
# chaque demande y est transmise en temps reel (ex: relais email, Make, Zapier, Discord).
LEADS_DIR=
ADMIN_NOTIFICATIONS_EMAIL=
NOTIFICATION_WEBHOOK_URL=
NOTIFICATION_WEBHOOK_SECRET=

# --- Deploiement Docker / Traefik ---
SITE_DOMAIN=
TRAEFIK_NETWORK=traefik

# --- Backend complet (optionnel, a renseigner pour activer le CRM/comptes Supabase) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
