# En production, mettre l'URL publique complète, ex: https://votre-domaine.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Origines autorisees pour les requetes navigateur mutantes.
# En production: https://votre-domaine.com,https://www.votre-domaine.com
CSRF_ALLOWED_ORIGINS=

# --- Mode vitrine (sans Supabase) ---
# Les demandes (contact / inscription / recrutement) sont toujours enregistrees
# dans un fichier (LEADS_DIR). En plus, si une URL de webhook est definie ci-dessous,
# chaque demande y est transmise en temps reel (ex: relais email, Make, Zapier, Discord).
LEADS_DIR=
ADMIN_NOTIFICATIONS_EMAIL=
NOTIFICATION_WEBHOOK_URL=
NOTIFICATION_WEBHOOK_SECRET=

# Provider email transactionnel (envoi REEL des notifications email aux familles).
# Brevo : free tier ~300 emails/jour. Si vide, repli sur le webhook ci-dessus, sinon les emails restent en file.
BREVO_API_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=

# Plateforme de formation EXTERNE (ES Viry-Châtillon Academy). La page /academy du site
# ne fait que presenter et rediriger vers cette URL (aucun compte gere cote site club).
ACADEMY_PLATFORM_URL=

# --- Deploiement Docker / Traefik ---
SITE_DOMAIN=
TRAEFIK_NETWORK=traefik
DEPLOY_ENV_FILE=.env.local
DEPLOY_MODE=crm
USE_SUPABASE_NETWORK=0

# --- Backend complet (CRM / comptes Supabase) ---
# Les 3 variables ci-dessous sont REQUISES pour activer l'admin, l'authentification
# et les donnees dynamiques. Si elles sont vides, le site tourne en mode vitrine.
# Docker doit aussi recevoir ces valeurs au build :
#   docker compose --env-file .env.local build
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
