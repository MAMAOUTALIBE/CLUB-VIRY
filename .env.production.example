# ===========================================================================
# Configuration de PRODUCTION — mode VITRINE — esvirychatillonfootball.org
# Sur le VPS :  cp .env.production.example .env.local   puis ajuster si besoin.
# ===========================================================================

# URL publique complete (SEO, sitemap, robots, liens canoniques, OpenGraph)
NEXT_PUBLIC_SITE_URL=https://esvirychatillonfootball.org
CSRF_ALLOWED_ORIGINS=https://esvirychatillonfootball.org,https://www.esvirychatillonfootball.org

# Domaine route par Traefik (sans le https://)
SITE_DOMAIN=esvirychatillonfootball.org

# --- Script de deploiement VPS ---
# Ces variables sont lues par deploy.sh depuis votre machine, pas par Next.js.
# Ne pas commiter un fichier rempli avec un vrai hote SSH.
# VPS_HOST=deploy@votre-vps
# VPS_PORT=22
# VPS_DIR=/opt/esviry
# DEPLOY_ENV_FILE=.env.local
# DEPLOY_MODE=crm
# USE_SUPABASE_NETWORK=0

# Dossier de capture des demandes (contact / inscription / recrutement).
# Monte en volume -> les demandes restent sur le VPS apres une mise a jour.
LEADS_DIR=/app/var/leads

# --- Notifications temps reel des demandes (optionnel, recommande) ---
# Sans webhook : les demandes sont stockees UNIQUEMENT dans var/leads (lisible sur le VPS).
# Avec webhook : chaque demande est transmise en direct (Make / Zapier / Discord / relais email).
# NOTIFICATION_WEBHOOK_URL=
# NOTIFICATION_WEBHOOK_SECRET=
# ADMIN_NOTIFICATIONS_EMAIL=esvirychatillon91170@gmail.com

# --- Plateforme Academy (formation) : URL externe vers laquelle la page /academy redirige ---
ACADEMY_PLATFORM_URL=

# --- Mode CRM complet (Supabase) ---
# Obligatoire si DEPLOY_MODE=crm. Lancer le build Docker avec :
#   docker compose --env-file .env.local build
# ou via :
#   VPS_HOST=deploy@votre-vps ./deploy.sh --check
# Laisser vide uniquement si DEPLOY_MODE=vitrine.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
